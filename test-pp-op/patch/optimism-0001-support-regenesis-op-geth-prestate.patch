From d8f7ec00fa87e580ba868c270e5ffc1514bc13a6 Mon Sep 17 00:00:00 2001
From: JimmyShi22 <417711026@qq.com>
Date: Wed, 30 Jul 2025 11:46:05 +0800
Subject: [PATCH] support regenesis op-geth prestate

---
 go.mod                                   | 4 ++--
 op-program/Dockerfile.repro              | 1 +
 op-program/Dockerfile.repro.dockerignore | 1 +
 3 files changed, 4 insertions(+), 2 deletions(-)

diff --git a/go.mod b/go.mod
index b09102566..7a3fc1675 100644
--- a/go.mod
+++ b/go.mod
@@ -304,9 +304,9 @@ require (
 	rsc.io/tmplfunc v0.0.3 // indirect
 )
 
-replace github.com/ethereum/go-ethereum => github.com/ethereum-optimism/op-geth v1.101511.1-dev.1.0.20250608235258-6005dd53e1b5
+// replace github.com/ethereum/go-ethereum => github.com/ethereum-optimism/op-geth v1.101511.1-dev.1.0.20250608235258-6005dd53e1b5
 
-//replace github.com/ethereum/go-ethereum => ../op-geth
+replace github.com/ethereum/go-ethereum => ./op-geth
 
 // replace github.com/ethereum-optimism/superchain-registry/superchain => ../superchain-registry/superchain
 
diff --git a/op-program/Dockerfile.repro b/op-program/Dockerfile.repro
index 2f861f3b2..b97057cd4 100644
--- a/op-program/Dockerfile.repro
+++ b/op-program/Dockerfile.repro
@@ -6,6 +6,7 @@ RUN apk add --no-cache make gcc musl-dev linux-headers git jq bash just
 
 COPY ./go.mod /app/go.mod
 COPY ./go.sum /app/go.sum
+COPY ./op-geth /app/op-geth
 
 WORKDIR /app
 
diff --git a/op-program/Dockerfile.repro.dockerignore b/op-program/Dockerfile.repro.dockerignore
index 15d6cf763..2844c7a06 100644
--- a/op-program/Dockerfile.repro.dockerignore
+++ b/op-program/Dockerfile.repro.dockerignore
@@ -5,6 +5,7 @@
 # internal dependencies
 !cannon/
 !op-alt-da/
+!op-geth/
 !op-node/
 !op-preimage/
 !op-program/
-- 
2.50.1

