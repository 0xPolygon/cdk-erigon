zkevm.l1-rollup-id: 39
zkevm.l1-first-block: 5158574
zkevm.l1-block-range: 1000
zkevm.l1-query-delay: 2000
zkevm.rpc-ratelimit: 250
zkevm.datastream-version: 3
zkevm.l2-short-circuit-to-verified-batch: false
zkevm.allow-internal-transactions: true

zkevm.increment-tree-always: true

externalcl: true
