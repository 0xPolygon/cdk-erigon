datadir: /data/erigon-data/xlayer-testnet
chain: xlayer-testnet
http: true
private.api.addr: localhost:9091
zkevm.l2-chain-id: 1952
zkevm.l2-sequencer-rpc-url: https://testrpc.xlayer.tech/terigon
zkevm.l2-datastreamer-url: teststream.xlayer.tech:8900
zkevm.l1-chain-id: 11155111
zkevm.l1-rpc-url: {your_eth_sepolia_l1_rpc}

log.console.verbosity: info

zkevm.address-sequencer: "0x98245d0adf4595c66f0a9db8e13c44cbff6be459"
zkevm.address-zkevm: "0x7b1472be9a0115c3076b9f30e6bab91b13b3be6b"
zkevm.address-admin: "0x00C832BFF84B2c6B1BFCa893cb0d56CcA2b2f65d"
zkevm.address-rollup: "0x32d33d5137a7cffb54c5bf8371172bcec5f310ff"
